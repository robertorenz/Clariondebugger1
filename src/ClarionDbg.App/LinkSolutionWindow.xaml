<Window x:Class="ClarionDbg.App.LinkSolutionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Link Solution to Clarion Version" Height="350" Width="660"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" ResizeMode="NoResize"
        Background="{StaticResource Panel}" Foreground="{StaticResource Fg}" FontFamily="Segoe UI">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Margin="0,0,0,12" TextWrapping="Wrap"
                   Text="This solution isn't linked to a Clarion version yet. Confirm the details so source files can be located via redirection / FileList. Your choice is saved next to the .sln."/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Solution" VerticalAlignment="Center" Margin="0,0,10,8"/>
        <TextBox   Grid.Row="1" Grid.Column="1" x:Name="TxtSln" Margin="0,0,0,8"
                   Background="{StaticResource Bg}" Foreground="{StaticResource Fg}"
                   BorderBrush="{StaticResource Border}" Padding="4,3"/>
        <Button    Grid.Row="1" Grid.Column="2" Content="Browse…" Width="80" Margin="8,0,0,8" Click="BrowseSln_Click"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Clarion version" VerticalAlignment="Center" Margin="0,0,10,8"/>
        <ComboBox  Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" x:Name="CmbVersion" Margin="0,0,0,8"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Configuration" VerticalAlignment="Center" Margin="0,0,10,8"/>
        <ComboBox  Grid.Row="3" Grid.Column="1" x:Name="CmbConfig" Margin="0,0,0,8" HorizontalAlignment="Left" Width="180"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Properties" VerticalAlignment="Center" Margin="0,0,10,8"
                   ToolTip="Optional: an explicit ClarionProperties.xml for a non-default ConfigDir install. Leave blank to use the detected versions."/>
        <TextBox   Grid.Row="4" Grid.Column="1" x:Name="TxtProps" Margin="0,0,0,8"
                   Background="{StaticResource Bg}" Foreground="{StaticResource Fg}"
                   BorderBrush="{StaticResource Border}" Padding="4,3"
                   ToolTip="Optional override — ClarionProperties.xml for a non-default ConfigDir. Repopulates the version list from that file."
                   LostFocus="TxtProps_LostFocus"/>
        <Button    Grid.Row="4" Grid.Column="2" Content="Browse…" Width="80" Margin="8,0,0,8" Click="BrowseProps_Click"/>

        <TextBlock Grid.Row="5" Grid.ColumnSpan="3" x:Name="TxtNote" VerticalAlignment="Top"
                   Foreground="{StaticResource Accent}" TextWrapping="Wrap" Margin="0,4,0,0"/>

        <StackPanel Grid.Row="6" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="BtnSave" Content="Save &amp; Use" Width="110" Click="Save_Click" IsDefault="True"/>
            <Button Content="Skip" Width="90" Click="Skip_Click" IsCancel="True" Margin="8,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
